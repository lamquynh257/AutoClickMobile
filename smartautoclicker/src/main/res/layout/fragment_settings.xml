<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:context=".settings.SettingsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/margin_vertical_default"
        android:layout_marginHorizontal="@dimen/margin_horizontal_default"
        android:orientation="vertical">

        <include layout="@layout/include_field_switch"
            android:id="@+id/field_show_scenario_filters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/margin_vertical_default" />

        <com.google.android.material.divider.MaterialDivider
            style="@style/AppTheme.Widget.Divider.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="1dp"/>

        <include layout="@layout/include_field_switch"
            android:id="@+id/field_legacy_actions_ui"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/margin_vertical_default" />

        <com.google.android.material.divider.MaterialDivider
            style="@style/AppTheme.Widget.Divider.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="1dp"/>

        <include layout="@layout/include_field_switch"
            android:id="@+id/field_legacy_notification_ui"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/margin_vertical_default"/>

        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/divider_force_entire_screen"
            style="@style/AppTheme.Widget.Divider.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="1dp"/>

        <include layout="@layout/include_field_switch"
            android:id="@+id/field_force_entire_screen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/margin_vertical_default" />

        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/divider_input_block_workaround"
            style="@style/AppTheme.Widget.Divider.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="1dp"/>

        <include layout="@layout/include_field_switch"
            android:id="@+id/field_input_block_workaround"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/margin_vertical_default" />

        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/divider_privacy_settings"
            style="@style/AppTheme.Widget.Divider.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="1dp"/>

        <include layout="@layout/include_field_selector"
            android:id="@+id/field_privacy_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/margin_vertical_default"/>

        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/divider_remove_ads"
            style="@style/AppTheme.Widget.Divider.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="1dp"/>

        <include layout="@layout/include_field_selector"
            android:id="@+id/field_remove_ads"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/margin_vertical_default"/>

        <com.google.android.material.divider.MaterialDivider
            style="@style/AppTheme.Widget.Divider.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="1dp"/>

        <include layout="@layout/include_field_selector"
            android:id="@+id/field_troubleshooting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/margin_vertical_default"/>

        <com.google.android.material.divider.MaterialDivider
            style="@style/AppTheme.Widget.Divider.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="1dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/telegram_settings_title"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginBottom="@dimen/margin_vertical_default"
            android:textColor="?attr/colorSecondary" />

        <include layout="@layout/include_field_text_input"
            android:id="@+id/field_telegram_bot_token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/margin_vertical_default" />

        <include layout="@layout/include_field_text_input"
            android:id="@+id/field_telegram_chat_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/margin_vertical_default" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_test_telegram"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="@string/telegram_button_test" />

    </LinearLayout>


</androidx.core.widget.NestedScrollView>
